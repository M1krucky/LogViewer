<Window x:Class="LogViewer.StatisticsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
        xmlns:local="clr-namespace:LogViewer"
        mc:Ignorable="d"
        Background="#1E1E1E"
        Foreground="White"
        
        Title="Statistics"
        Height="700"
        Width="900">
    

    <!-- main layout container for statistics and chart -->
    <Grid Margin="20">

        <!-- divide the window into summary, distribution chart, and error trend chart areas -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- display summary statistics for the current filtered log entries -->
        <Grid Grid.Row="0">

            <!-- divide the statistics area into labels and values -->
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- create one row for each statistic -->
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" FontSize="15" Text="Total entries:"/>
            <TextBlock Name="TotalEntriesTextBlock" Grid.Row="0" Grid.Column="1" Margin="10,0,0,0" FontSize="15" FontWeight="SemiBold" Text="0"/>

            <TextBlock Grid.Row="1" Grid.Column="0" FontSize="15" Text="INFO:"/>
            <TextBlock Name="InfoCountTextBlock" Grid.Row="1" Grid.Column="1" Margin="10,0,0,0" FontSize="15" FontWeight="SemiBold" Text="0"/>

            <TextBlock Grid.Row="2" Grid.Column="0" FontSize="15" Text="WARNING:"/>
            <TextBlock Name="WarningCountTextBlock" Grid.Row="2" Grid.Column="1" Margin="10,0,0,0" FontSize="15" FontWeight="SemiBold" Text="0"/>

            <TextBlock Grid.Row="3" Grid.Column="0" FontSize="15" Text="ERROR:"/>
            <TextBlock Name="ErrorCountTextBlock" Grid.Row="3" Grid.Column="1" Margin="10,0,0,0" FontSize="15" FontWeight="SemiBold" Text="0"/>

            <TextBlock Grid.Row="4" Grid.Column="0" FontSize="15" Text="Latest log:"/>
            <TextBlock Name="LatestLogTextBlock" Grid.Row="4" Grid.Column="1" Margin="10,0,0,0" FontSize="15" FontWeight="SemiBold" Text="-"/>

        </Grid>

        <!-- display the log level distribution chart below the summary statistics -->
        <StackPanel Grid.Row="1"
                    Margin="0,20,0,0">

            <!-- chart title -->
            <TextBlock Text="Log Level Distribution"
                        FontSize="14"
                        FontWeight="Bold"
                        Margin="0,0,0,10"/>

            <!-- display the LiveCharts2 bar chart for INFO, WARNING, and ERROR counts -->
            <lvc:CartesianChart
                Height="245"
                Background="Transparent"
                Series="{Binding LogLevelSeries}"
                XAxes="{Binding LogLevelXAxes}"
                YAxes="{Binding LogLevelYAxes}" />


        </StackPanel>

        <!-- display the error trend chart below the log level distribution chart -->
        <Grid Grid.Row="2"
        Margin="0,20,0,0">

            <!-- divide the error trend area into a header row and a chart row -->
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- display the chart title and grouping selector -->
            <DockPanel Grid.Row="0"
               Margin="0,0,0,10">

                <!-- chart title -->
                <TextBlock Text="Error Trend"
                   FontSize="14"
                   FontWeight="Bold"
                   VerticalAlignment="Center"/>

                <!-- display the grouping selector on the right side -->
                <StackPanel DockPanel.Dock="Right"
                    Orientation="Horizontal">

                    <!-- grouping selector label -->
                    <TextBlock Text="Group by:"
                       Margin="20,0,5,0"
                       VerticalAlignment="Center"/>

                    <!-- allow the user to group ERROR entries by different time periods -->
                    <ComboBox Name="ErrorTrendGroupingComboBox"
                      Width="90"
                      SelectedIndex="1"
                      VerticalContentAlignment="Center"
                      SelectionChanged="ErrorTrendGroupingComboBox_SelectionChanged">

                        <ComboBoxItem Content="Hour"/>
                        <ComboBoxItem Content="Day"/>
                        <ComboBoxItem Content="Week"/>
                        <ComboBoxItem Content="Month"/>

                    </ComboBox>

                </StackPanel>

            </DockPanel>


            <!-- display the LiveCharts2 line chart showing ERROR counts over time -->
                    <lvc:CartesianChart Grid.Row="1"
                        Background="Transparent"
                        Series="{Binding ErrorTrendSeries}"
                        XAxes="{Binding ErrorTrendXAxes}"
                        YAxes="{Binding ErrorTrendYAxes}"/>


                </Grid>

    </Grid>

</Window>