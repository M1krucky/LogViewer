<Window x:Class="LogViewer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LogViewer"
        mc:Ignorable="d"
		
        Title="MainWindow"
        Height="550"
        Width="1070">

	<DockPanel>
		<!-- provide the main application menu for file management and user assistance -->
		<Menu DockPanel.Dock="Top">
			<MenuItem Header="_File">
				<MenuItem Header="_Open Log File..." Click="OpenFileButton_Click" />
				
				<Separator />
				
	            <!-- display the list of recently opened log files -->
				<MenuItem x:Name="RecentFilesMenuItem"
						  Header="_Recent Files" />

				<Separator />
				
				<MenuItem Header="E_xit" Click="ExitMenuItem_Click" />
			</MenuItem>

			<MenuItem Header="_Help">
				<MenuItem Header="_About" Click="AboutMenuItem_Click" />
			</MenuItem>
		</Menu>

		<!-- display current application status and active log file information -->
		<StatusBar DockPanel.Dock="Bottom">
			<StatusBarItem>
				<TextBlock x:Name="CurrentFileTextBlock"
						   Text="File: No file opened" />
			</StatusBarItem>
		</StatusBar>
		
		<!-- main layout container -->
		<Grid>

			<!-- divide the window into three rows: toolbar, log table, and details panel -->
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="*"/>
				<RowDefinition Height="Auto"/>
			</Grid.RowDefinitions>

			<!-- top toolbar containing file operations, filters, and statistics -->
			<StackPanel Orientation="Horizontal" Margin="10">

				<Button Name="OpenFileButton"
						Content="Open Log File"
						Width="120"
						Height="30"
						Click="OpenFileButton_Click"/>

				<TextBlock Text="Search:"
						   Margin="20,0,5,0"
						   VerticalAlignment="Center"/>

				<TextBox Name="SearchTextBox"
						 Width="200"
						 TextChanged="SearchTextBox_TextChanged"/>

				<!-- allow the user to choose whether any or all search words must match -->
				<ComboBox Name="SearchModeComboBox"
						  Width="70"
						  Margin="5,0,0,0"
						  SelectedIndex="0"
						  VerticalContentAlignment="Center"
						  SelectionChanged="SearchModeComboBox_SelectionChanged">

					<ComboBoxItem Content="OR"/>
					<ComboBoxItem Content="AND"/>

				</ComboBox>

				<TextBlock Text="Level:"
						   VerticalAlignment="Center"
						   Margin="10,0,5,0"/>

				<ComboBox Name="LevelFilterComboBox"
						  Width="100"
						  SelectedIndex="0"
						  VerticalContentAlignment="Center"
						  SelectionChanged="LevelFilterComboBox_SelectionChanged">

					<ComboBoxItem Content="All"/>
					<ComboBoxItem Content="INFO"/>
					<ComboBoxItem Content="WARNING"/>
					<ComboBoxItem Content="ERROR"/>

				</ComboBox>

				<TextBlock Text="From:"
						   VerticalAlignment="Center"
						   Margin="10,0,5,0"/>

				<DatePicker Name="FromDatePicker"
							Width="120"
							VerticalAlignment="Center"
							SelectedDateChanged="DatePicker_SelectedDateChanged"/>

				<TextBlock Text="To:"
						   VerticalAlignment="Center"
						   Margin="10,0,5,0"/>

				<DatePicker Name="ToDatePicker"
							Width="120"
							VerticalAlignment="Center"
							SelectedDateChanged="DatePicker_SelectedDateChanged"/>

				<Button Name="StatisticsButton"
						Content="Statistics"
						Width="100"
						Height="30"
						Margin="10,0,0,0"
						Click="StatisticsButton_Click"/>

			</StackPanel>

			<!-- display parsed and filtered log entries -->
			<DataGrid Name="LogGrid"
					  Grid.Row="1"
					  AutoGenerateColumns="False"
					  CanUserAddRows="False"
					  SelectionChanged="LogGrid_SelectionChanged"> 

				<!-- highlight log entries based on their severity level -->
				<DataGrid.RowStyle>

					<Style TargetType="DataGridRow">
						<Style.Triggers>

							<DataTrigger Binding="{Binding Level}" Value="ERROR">
								<Setter Property="Background" Value="#FFCDD2"/>
							</DataTrigger>

							<DataTrigger Binding="{Binding Level}" Value="WARNING">
								<Setter Property="Background" Value="#FFF9C4"/>
							</DataTrigger>

						</Style.Triggers>
					</Style>

				</DataGrid.RowStyle>

				<!-- define the columns displayed in the log table -->
				<DataGrid.Columns>

					<!-- display the timestamp of each log entry -->
					<DataGridTextColumn Header="Timestamp"
										Binding="{Binding Timestamp}"/>

					<!-- display the severity level of each log entry -->
					<DataGridTextColumn Header="Level"
										Binding="{Binding Level}"/>

					<!-- display the log message of each log entry -->
					<DataGridTextColumn Header="Message"
										Binding="{Binding Message}"/>

				</DataGrid.Columns>

			</DataGrid>

			<!-- display details of the currently selected log entry -->
			<Border Grid.Row="2"
					Margin="10"
					Padding="10"
					BorderBrush="LightGray"
					BorderThickness="1">

				<!-- organize the selected log entry information vertically -->
				<StackPanel>

					<TextBlock Text="Selected Log Details"
							   FontWeight="Bold"
							   FontSize="14"
							   Margin="0,0,0,10"/>

					<TextBlock Name="SelectedTimestampTextBlock"
							   Text="Timestamp: -"
							   Margin="0,0,0,5"/>

					<TextBlock Name="SelectedLevelTextBlock"
							   Text="Level: -"
							   Margin="0,0,0,5"/>

					<TextBlock Name="SelectedMessageTextBlock"
							   Text="Message: -"
							   TextWrapping="Wrap"/>

					<!-- show loading status while a log file is being loaded -->
					<StackPanel x:Name="LoadingPanel"
								Orientation="Horizontal"
								Visibility="Collapsed"
								Margin="0,8,0,8">
						<ProgressBar Width="160"
									 Height="16"
									 IsIndeterminate="True"
									 Margin="0,0,10,0" />

						<TextBlock Text="Loading log file..."
								   VerticalAlignment="Center" />
					</StackPanel>

				</StackPanel>

			</Border>

		</Grid>

	</DockPanel>

</Window>